APP_NAME=Zehn-Arch
APP_VERSION=1.0.0
ROOT_PATH=/fast-arch
RATE_LIMIT_MAX_REQUESTS=1000
RATE_LIMIT_WINDOW_SECONDS=600
GZIP_MINIMUM_SIZE=500
CORS_MAX_AGE=3600
CORS_ORIGINS=["http://localhost:3000"]
ALLOWED_HOSTS=["*"]

SENTRY_DSN=
DEBUG=True
ENVIRONMENT=local

JWT_SECRET_KEY=mysecretkey
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=10080
JWT_REFRESH_TOKEN_EXPIRE_HOURS=168

POSTGRES_USER=postgres
POSTGRES_PASSWORD=mysecretpassword
POSTGRES_DB=mydb

DB_HOST=postgres
DB_PORT=5432
DB_USER=zehn_architectury_admin
DB_PASS=ping1234
DB_NAME=zehn_architectury_db

OPENAI_API_KEY=

# Minio
MINIO_URL=localhost:9001
MINIO_PUBLIC_URL=localhost:9001
MINIO_ENDPOINT=localhost:9001
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=False
AWS_STOROGE_REGION=us-east-1

MINIO_BUCKET=minio-bucket

# Redis
REDIS_URL=redis://localhost:6379

# Mongo
MONGO_URI=mongodb://root:example@mongo:27017/admin
MONGO_DB_NAME=zehn_architectury
MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=strongpassword123

CELERY_BROKER_URL=amqp://guest:guest@rabbitmq:5672/
CELERY_RESULT_BACKEND=redis://redis:6379/1
